global:
  scrape_interval: 15s
  evaluation_interval: 15s

rule_files:
  - /etc/prometheus/alerts.yml

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets: ["localhost:9090"]
        labels:
          instance: server

  - job_name: node-exporter-server
    static_configs:
      - targets: ["node_exporter:9100"]
        labels:
          instance: server

  - job_name: cadvisor-server
    static_configs:
      - targets: ["cadvisor:8080"]
        labels:
          instance: server

  - job_name: node-exporter-rpi
    static_configs:
      - targets: ["rpi:{{ hostvars[groups['pi'][0]].rpi_service_ports.node_exporter }}"]
        labels:
          instance: rpi

  - job_name: cadvisor-rpi
    static_configs:
      - targets: ["rpi:{{ hostvars[groups['pi'][0]].rpi_service_ports.cadvisor }}"]
        labels:
          instance: rpi
