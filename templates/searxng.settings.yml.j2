use_default_settings: true

general:
  debug: false
  instance_name: "SearXNG"

server:
  secret_key: "{{ searxng.secret_key }}"
  limiter: false
  image_proxy: true
  method: "POST"

ui:
  static_use_hash: true
  default_locale: "en"
  query_in_title: true
  infinite_scroll: false
  center_alignment: false
  default_theme: simple
  theme_args:
    simple_style: dark

search:
  safe_search: 0
  autocomplete: "google"
  default_lang: "en"
  formats:
    - html
    - json

engines:
  - name: google
    disabled: false
  - name: duckduckgo
    disabled: false
  - name: wikipedia
    disabled: false
  - name: github
    disabled: false
  - name: stackoverflow
    disabled: false
  - name: arxiv
    disabled: false

redis:
  url: redis://redis:6379/0
